# Anthropic API key for the LLM pipeline stages (freetext extraction, thread
# linking, handover generation). Server-only; never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-...

# Bearer token required on every /api/handover request.
VOUCH_API_KEY=changeme-dev-token

# Optional: pin the model. Defaults to claude-sonnet-4-6.
VOUCH_MODEL=claude-sonnet-4-6
